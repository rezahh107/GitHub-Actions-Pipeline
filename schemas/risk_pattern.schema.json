{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain Risk Pattern",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "project_type",
    "detection_signals",
    "risk_patterns"
  ],
  "properties": {
    "project_type": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "detection_signals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/detectionSignal"
      }
    },
    "risk_patterns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/riskPattern"
      }
    },
    "notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "detectionSignal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signal"
      ],
      "properties": {
        "signal": {
          "$ref": "#/definitions/nonEmptyString"
        }
      }
    },
    "riskPattern": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "description",
        "typical_trigger",
        "detectability",
        "suggested_gate"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "typical_trigger": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "detectability": {
          "type": "string",
          "enum": [
            "easy",
            "medium",
            "hard"
          ]
        },
        "suggested_gate": {
          "$ref": "#/definitions/nonEmptyString"
        }
      }
    }
  }
}
