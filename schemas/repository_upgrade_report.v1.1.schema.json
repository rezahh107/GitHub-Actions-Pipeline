{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Upgrade Report v1.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_version", "canonicalization_version", "generated_at",
    "evidence_sha256", "analysis_basis_sha256", "repository",
    "operating_mode", "mode_policy", "repository_model", "profiles",
    "history_analysis", "workflow_telemetry", "cold_start",
    "recommendations", "diagnostics"
  ],
  "properties": {
    "report_version": {"const": "1.1.0"},
    "canonicalization_version": {"const": "1"},
    "generated_at": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"},
    "evidence_sha256": {"$ref": "#/definitions/sha256"},
    "analysis_basis_sha256": {"$ref": "#/definitions/sha256"},
    "repository": {"type": "string", "minLength": 1},
    "operating_mode": {"enum": ["minimal-safe-ci", "deep-repository-upgrade"]},
    "mode_policy": {"type": "object"},
    "repository_model": {"$ref": "#/definitions/repositoryModel"},
    "profiles": {"type": "object"},
    "history_analysis": {"type": "object"},
    "workflow_telemetry": {"type": "object"},
    "cold_start": {"type": "object"},
    "recommendations": {"type": "object"},
    "diagnostics": {"type": "array"},
    "minimal_gate_plan": {"type": "object"},
    "deep_audit": {"type": "object"},
    "staged_upgrade": {"type": "object"},
    "implementation_package": {"$ref": "#/definitions/implementationPackage"}
  },
  "allOf": [
    {
      "if": {"properties": {"operating_mode": {"const": "minimal-safe-ci"}}},
      "then": {
        "required": ["minimal_gate_plan"],
        "not": {"anyOf": [
          {"required": ["deep_audit"]},
          {"required": ["staged_upgrade"]},
          {"required": ["implementation_package"]}
        ]}
      }
    },
    {
      "if": {"properties": {"operating_mode": {"const": "deep-repository-upgrade"}}},
      "then": {
        "required": ["deep_audit", "staged_upgrade", "implementation_package"],
        "not": {"required": ["minimal_gate_plan"]}
      }
    }
  ],
  "definitions": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "evidence": {
      "type": "object",
      "required": ["state", "references", "rationale"],
      "properties": {
        "state": {"enum": ["observed", "derived", "inferred", "unavailable", "not_applicable"]},
        "references": {"type": "array", "items": {"type": "string"}},
        "rationale": {"type": "string"},
        "confidence": {"enum": ["low", "medium", "high"]}
      }
    },
    "capability": {
      "type": "object",
      "required": ["capability_id", "state", "evidence"],
      "properties": {
        "capability_id": {"type": "string"},
        "state": {"enum": ["absent", "nominal", "partial", "operational", "operational_but_weak", "unknown", "not_applicable"]},
        "evidence": {"$ref": "#/definitions/evidence"},
        "repair_hint": {"type": "string"}
      }
    },
    "repositoryModel": {
      "type": "object",
      "required": ["model_version", "capabilities", "components", "semantic_model", "relationships"],
      "properties": {
        "model_version": {"const": "1.1.0"},
        "capabilities": {"type": "array", "items": {"$ref": "#/definitions/capability"}},
        "components": {"type": "array"},
        "semantic_model": {"type": "object"},
        "relationships": {"type": "array"}
      }
    },
    "implementationPackage": {
      "type": "object",
      "required": ["implementation_contract_version", "mutation_default", "actions", "summary", "security_boundary"],
      "properties": {
        "implementation_contract_version": {"const": "1.0.0"},
        "mutation_default": {"const": "dry_run"},
        "repository": {"type": ["string", "null"]},
        "analysis_basis_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
        "actions": {"type": "array", "items": {"type": "object"}},
        "summary": {"type": "object"},
        "security_boundary": {"type": "string"}
      }
    }
  }
}
