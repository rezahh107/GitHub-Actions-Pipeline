{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Repository Outcomes v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["outcome_contract_version", "outcomes"],
  "properties": {
    "outcome_contract_version": {"const": "1.0.0"},
    "outcomes": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/definitions/outcome"}
    }
  },
  "definitions": {
    "sha1": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "capabilityState": {"enum": ["absent", "nominal", "partial", "operational", "operational_but_weak", "unknown", "not_applicable"]},
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": ["outcome_id", "repository_fingerprint", "profile_ids", "recommendation_id", "capability_id", "pre_capability_state", "implementation_status", "post_capability_state", "validation"],
      "properties": {
        "outcome_id": {"type": "string", "minLength": 1, "maxLength": 200, "pattern": "^[A-Za-z0-9._:-]+$"},
        "repository_fingerprint": {"$ref": "#/definitions/sha256"},
        "profile_ids": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "recommendation_id": {"type": "string", "minLength": 1},
        "capability_id": {"type": "string", "minLength": 1},
        "pre_capability_state": {"$ref": "#/definitions/capabilityState"},
        "implementation_status": {"enum": ["applied", "rejected", "failed", "not_applied"]},
        "post_capability_state": {"$ref": "#/definitions/capabilityState"},
        "validation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["exact_head_sha", "workflow_head_sha", "workflow_conclusion"],
          "properties": {
            "exact_head_sha": {"$ref": "#/definitions/sha1"},
            "workflow_head_sha": {"$ref": "#/definitions/sha1"},
            "workflow_conclusion": {"enum": ["success", "failure", "cancelled", "timed_out", "action_required", "neutral", "skipped", "stale", "startup_failure"]}
          }
        }
      }
    }
  }
}
