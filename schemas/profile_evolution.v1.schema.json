{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Profile Evolution Proposals v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["profile_evolution_contract_version", "minimum_distinct_repositories", "automatic_registry_mutation", "proposals", "excluded_outcomes", "diagnostics"],
  "properties": {
    "profile_evolution_contract_version": {"const": "1.0.0"},
    "minimum_distinct_repositories": {"type": "integer", "minimum": 2},
    "automatic_registry_mutation": {"const": false},
    "proposals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["proposal_id", "profile_id", "capability_id", "recommendation_id", "proposal_type", "status", "distinct_repository_count", "pre_capability_states", "post_capability_states", "evidence", "required_review"],
        "properties": {
          "proposal_id": {"type": "string"},
          "profile_id": {"type": "string"},
          "capability_id": {"type": "string"},
          "recommendation_id": {"type": "string"},
          "proposal_type": {"const": "review_baseline_or_recipe_promotion"},
          "status": {"const": "proposed_for_human_review"},
          "distinct_repository_count": {"type": "integer", "minimum": 2},
          "pre_capability_states": {"type": "array", "items": {"type": "string"}},
          "post_capability_states": {"type": "array", "items": {"type": "string"}},
          "evidence": {"type": "object"},
          "required_review": {"type": "array", "minItems": 1, "items": {"type": "string"}}
        }
      }
    },
    "excluded_outcomes": {"type": "array"},
    "diagnostics": {"type": "array"}
  }
}
